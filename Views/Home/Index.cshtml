@model HomePageViewModel
@{
    ViewData["Title"] = "Početna";
}

<section class="hero-box">
    <h1>Profesionalni webshop za prodaju akrilnih boja</h1>
    <p>Dobrodošli u Akril Art Shop - premium boje, kistovi, platna i pribor.</p>
</section>

<section>
    <div class="section-header">
        <h2>Aktualne akcije</h2>
        <a asp-controller="Products" asp-action="Index" asp-route-sortBy="priceAsc">Pogledaj sve</a>
    </div>
    <div class="grid">
        @foreach (var product in Model.SaleProducts)
        {
            <article class="card">
                <img src="@product.ImageUrl" alt="@product.Name" />
                <h3>@product.Name</h3>
                <p>@product.Description</p>
                <p class="price">@product.Price.ToString("0.00") €</p>
                <span class="pill">AKCIJA</span>
            </article>
        }
    </div>
</section>

<section>
    <div class="section-header">
        <h2>Najprodavaniji proizvodi</h2>
    </div>
    <div class="grid">
        @foreach (var product in Model.BestSellerProducts)
        {
            <article class="card">
                <img src="@product.ImageUrl" alt="@product.Name" />
                <h3>@product.Name</h3>
                <p>@product.Description</p>
                <p class="price">@product.Price.ToString("0.00") €</p>
                <span class="pill bestseller">TOP</span>
            </article>
        }
    </div>
</section>
