@model ErrorViewModel
@{
    ViewData["Title"] = "Greška";
}

<main class="section container">
    <h1>Došlo je do greške</h1>
    <p>Pokušajte ponovno kasnije.</p>
    @if (Model.ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Natrag na početnu</a>
</main>
